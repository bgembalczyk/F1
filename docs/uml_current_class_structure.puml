package "Infrastructure" {
    interface HttpClientProtocol {
        + get(url): HttpResponse
    }

    class HttpClient {
        + get(url, policy): HttpResponse
    }

    class UrllibHttpClient {
        + get(url): HttpResponse
    }

    abstract class HttpPolicy {
        + apply(request): HttpResponse
    }

    class RetryPolicy {
        - max_retries: int
        - backoff_factor: float
    }

    class RateLimiterPolicy {
        - min_delay: float
    }

    class ResponseCachePolicy {
        - cache_dir: Path
    }

    class CacheAdapter {
        - file_cache: FileCache
        + get(url): str
    }

    class SourceAdapter {
        + get(url): str
    }
}

HttpClientProtocol <|.. HttpClient
HttpClientProtocol <|.. UrllibHttpClient
HttpPolicy <|-- RetryPolicy
HttpPolicy <|-- RateLimiterPolicy
HttpPolicy <|-- ResponseCachePolicy

F1Scraper --> SourceAdapter: uses
SourceAdapter --> CacheAdapter: may use
CacheAdapter --> HttpClient: uses
HttpClient --> HttpPolicy: applies

package "Models & Data" {
    class Circuit {
        + circuit_name: str
        + location: str
        + country: str
        + first_year: int
        + last_year: int
        + circuit_length: float
    }

    class Driver {
        + driver: str
        + nationality: str
        + seasons_competed: List[SeasonRecord]
        + race_entries: int
        + race_wins: int
    }

    class Constructor {
        + constructor_name: str
        + nationality: str
        + first_season: int
        + last_season: int
    }

    class Season {
        + season: int
        + rounds: List[RoundRecord]
        + drivers_champion: str
        + constructors_champion: str
    }

    class RecordFactory {
        + {static} build_circuit_record(data): Circuit
        + {static} build_driver_record(data): Driver
        + {static} build_constructor_record(data): Constructor
        + {static} build_season_record(data): Season
    }

    class FieldNormalizer {
        + {static} normalize_int(value): int
        + {static} normalize_float(value): float
        + {static} normalize_link(value): LinkRecord
        + {static} normalize_seasons(value): List[SeasonRecord]
    }
}

RecordFactory --> FieldNormalizer: uses
F1TableScraper --> RecordFactory: uses

