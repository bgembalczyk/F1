title F1 Wikipedia Scraper - Current Class Structure and Hierarchy

package "Wiki Scraper" {
    class WikiScraper {
        - http_client: Any
        - header_parser: HeaderParser
        - body_content_parser: BodyContentParser
        --
        + scrape(url: str): dict
        # _fetch(url: str): str
        # _parse(url: str, soup: BeautifulSoup): dict
    }

    note right of WikiScraper
        Pobiera HTML strony za pomocą http_client.
        Klient decyduje o pobieraniu bezpośrednim lub z cache.
        Klasa obsługująca kilka scraperów = DataExtractor.
    end note
}

package "Wiki Parsers - Page Level" {
    abstract class WikiParser {
        + {abstract} parse(element: Tag): Any
    }

    class HeaderParser {
        --
        + parse(element: Tag): dict
        + {static} find_header(soup: BeautifulSoup): Tag | None
    }

    class BodyContentParser {
        - category_links_parser: CategoryLinksParser
        - content_text_parser: ContentTextParser
        --
        + parse(element: Tag): dict
        + {static} find_body_content(soup: BeautifulSoup): Tag | None
    }

    class CategoryLinksParser {
        --
        + parse(element: Tag): dict
    }

    class ContentTextParser {
        - section_parser: SectionParser
        --
        + parse(element: Tag): dict
    }
}

